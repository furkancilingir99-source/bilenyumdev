# Bilenyum site koruması — Vercel → Settings → Environment Variables

# Zorunlu: oturum imzalama anahtarı (en az 32 karakter)
AUTH_SECRET=buraya-uzun-rastgele-bir-metin-yazin-min-32-karakter

# ===== ÇOK KULLANICI (ekip için — önerilen) =====
# Tek satır JSON. Her kişi: email + password
# Vercel'de Value alanına aşağıdakini yapıştırın (tek satır):
AUTH_USERS=[{"email":"sen@firma.com","password":"GucluSifre1!"},{"email":"ekip@firma.com","password":"GucluSifre2!"}]

# ===== TEK KULLANICI (eski yöntem — AUTH_USERS yoksa) =====
# AUTH_USERNAME=sen@firma.com
# AUTH_PASSWORD=guclu-sifreniz
