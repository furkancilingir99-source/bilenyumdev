# Opsiyonel — Vercel env gerekmez; config/auth-users.txt kullanılır.
# İsterseniz override edebilirsiniz:

# AUTH_SECRET=uzun-rastgele-metin-en-az-32-karakter
# AUTH_USERS=furkan@firma.com:Sifre123!,ayse@firma.com:Ayse456!
# AUTH_ADMIN_KEY=bilenyum-ekip-kontrol-2026

# Alternatif tek kullanıcı (auth-users.txt yoksa):
# AUTH_USERNAME=furkan@firma.com
# AUTH_PASSWORD=Sifre123!
